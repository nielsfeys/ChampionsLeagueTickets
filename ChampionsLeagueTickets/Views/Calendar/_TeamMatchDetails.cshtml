@using ChampionsLeagueTickets.ViewModels;
@model IEnumerable<MatchVM>


@if (Model == null || !Model.Any()) {
    <p>No matches found.</p>
}
else {
    <table id="MatchTable" class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Home Team</th>
                <th>Away Team</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Date</td>
                    <td>@item.HomeTeam</td>
                    <td>@item.AwayTeam</td>
                    <td>
                        <a asp-controller="Tickets" asp-action="Index" asp-route-matchId="@item.Id">Buy Tickets</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}