@using ChampionsLeagueTickets.ViewModels;
@model HotelSearchVM;

@{
    ViewData["Title"] = "Hotel Search";
}

<h1>Find a Hotel</h1>

@if (TempData["Error"] != null) {
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="post" asp-controller="Hotel" asp-action="Search">
    @Html.AntiForgeryToken()
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <label class="form-label">Home Club</label>
            <select asp-for="Destination" class="form-control">
            @foreach(var club in ViewBag.Clubs)
                {
                    <option value="@club.CityId">@club.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Check-in</label>
            <input asp-for="CheckIn" type="date" class="form-control"/>
        </div>
        <div class="col-md-2">
            <label class="form-label">Check-out</label>
            <input asp-for="CheckOut" type="date" class="form-control"/>
        </div>
        <div class="col-md-2">
            <label class="form-label">Adults</label>
            <input asp-for="Adults" type="number" class="form-control" min="1"/>
        </div>
        <div class="col-md-2">
            <label class="form-label">Rooms</label>
            <input asp-for="RoomQuantity" type="number" class="form-control" min="1" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
        
    </div>
</form>

@if (Model.Results.Count > 0) {
    <h2>Available Hotels</h2>
    <div class="row">
    @foreach (var hotel in Model.Results) {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">@hotel.HotelName</h5>
                    @if (hotel.ReviewScore.HasValue) {
                        <p class="mb-1">
                            <span class="badge bg-primary">Rating: @hotel.ReviewScore.Value.ToString("F1")</span>
                        </p>
                    }
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <strong>€@hotel.Price.ToString("F2")</strong>
                    <a class="btn btn-sm btn-primary" asp-action="Book">Book</a>
                </div>
            </div>
        </div>
    }
    </div>
}
