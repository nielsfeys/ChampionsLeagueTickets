@using ChampionsLeagueTickets.ViewModels;
@model ShoppingCartVM;

@{
    ViewData["Title"] = "Shopping Cart";
}

<h1>Shopping Cart</h1>
@if(TempData["Error"] != null)
{
     <div class="alert alert-danger">@TempData["Error"]</div>
}
@if(TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}


@if(Model.SeasonTickets.Count > 0) {
    <h2>Season Tickets</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Club</th>
                <th>Ring</th>
                <th>Location</th>
                <th>Price</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.SeasonTickets) {
            <tr>
                <td>@item.HomeClubName</td>
                <td>@item.Ring</td>
                <td>@item.Location</td>
                <td>@($"€{item.Price:F2}")</td>
                <td><form method="post" asp-controller="ShoppingCart" asp-action="DeleteSeasonTicket" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sectionId" value="@item.SectionId" />
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form></td>
            </tr>
        }
        </tbody>
    </table>
        

}
@if(Model.SeasonTickets.Count > 0 && Model.DayTickets.Count > 0) {
    <hr />
}

@if(Model.DayTickets.Count > 0) {
    <h2>Single Match Tickets</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Home Team</th>
                <th>Away Team</th>
                <th>Ring</th>
                <th>Location</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.DayTickets) {
            <tr>
                <td>@item.MatchDate</td>
                <td>@item.HomeClubName</td>
                <td>@item.AwayClubName</td>
                <td>@item.Ring</td>
                <td>@item.Location</td>
                <td>@($"€{item.Price:F2}")</td>
                <td>@item.Quantity</td>
                <td><form method="post" asp-controller="ShoppingCart" asp-action="DeleteDayTicket" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sectionId" value="@item.SectionId" />
                        <input type="hidden" name="matchId" value="@item.MatchId" />
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form></td>
            </tr>
        }
        </tbody>
    </table>
}
<form method="post" asp-controller="ShoppingCart" asp-action="Checkout">
    @Html.AntiForgeryToken()
    <hr />
    <button class="btn btn-primary" type="submit">Checkout</button>
</form>